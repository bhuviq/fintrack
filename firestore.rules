rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USER PROFILE
    // Only the user themselves can create, read, or update their own profile.
    match /users/{userId} {
      allow read, update, create: if isOwner(userId);
    }

    // DEFAULT CATEGORIES (seeded once by the app)
    // This collection is special. Any authenticated user can read from it,
    // and they can also create documents (which is how the one-time seeding works).
    // No one can update or delete them from the client, making them immutable.
    match /default-categories/{categoryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; 
    }
    
    // USER-CREATED CATEGORIES
    match /categories/{categoryId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // ACCOUNTS
    match /accounts/{accountId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // BUDGETS
    match /budgets/{budgetId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // GOALS
    match /goals/{goalId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // INVESTMENTS
    match /investments/{investmentId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // INSURANCE
    match /insurance/{insuranceId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // TRANSACTIONS
    match /transactions/{transactionId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
  }
}
